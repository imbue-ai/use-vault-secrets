#!/bin/bash
# Authenticate to Imbue Vault from GitHub Actions and inject secrets into the
# job environment. This backs the export-secrets composite action in
# .github/actions/export-secrets/; see its README for usage.
#
# Requests a GitHub Actions OIDC token (audience "imbue-vault"), exchanges it
# for a Vault token via the jwt_github_actions auth backend using the role in
# $VAULT_AUTH_ROLE, then fetches each requested secret and appends it to
# $GITHUB_ENV (masked in the logs).
#
# Talks to the Vault HTTP API directly with curl + jq, both preinstalled on
# GitHub-hosted runners, so no Vault CLI is needed.
#
# Usage: export-secrets-github PATH[@VERSION]...
#   e.g. export-secrets-github shared/modal/MODAL_TOKEN_ID sculptor-test/FOO@3
# The last path component is used as the environment variable name, and the
# value is read from the secret's "value" field (our secret-organization
# convention). An optional @VERSION suffix pins a specific KV v2 version.
#
# Required environment (all provided by GitHub Actions when the job has
# `permissions: id-token: write`, except VAULT_AUTH_ROLE):
#   VAULT_AUTH_ROLE                 the Vault role to assume
#   ACTIONS_ID_TOKEN_REQUEST_TOKEN  used to mint the OIDC token
#   ACTIONS_ID_TOKEN_REQUEST_URL    used to mint the OIDC token
#   GITHUB_ENV                      file the resulting variables are written to
# Optional environment:
#   EXPORT_VAULT_TOKEN=true         also export VAULT_TOKEN for later steps
#   GITHUB_OUTPUT                   if set, the pinned versions are written here
set -euo pipefail

VAULT_ADDR="https://vault-cluster-public-vault-df29b16f.9b573ab7.z1.hashicorp.cloud:8200"
VAULT_NAMESPACE="admin"
AUDIENCE="imbue-vault"
AUTH_PATH="jwt_github_actions"
MOUNT="secrets"

require() {
  # require VARNAME [hint]
  if [[ -z "${!1:-}" ]]; then
    echo >&2 "$1 is not set.${2:+ $2}"
    exit 1
  fi
}
require VAULT_AUTH_ROLE
require ACTIONS_ID_TOKEN_REQUEST_URL "Does the job have 'permissions: id-token: write'?"
require ACTIONS_ID_TOKEN_REQUEST_TOKEN "Does the job have 'permissions: id-token: write'?"
require GITHUB_ENV

# Append NAME=VALUE to $GITHUB_ENV using a heredoc, which is safe for values
# that contain newlines or other special characters.
put_env() {
  printf '%s<<__VAULT_EOF__\n%s\n__VAULT_EOF__\n' "$1" "$2" >> "$GITHUB_ENV"
}

# Hide a value from the logs. Skip empty strings (GitHub warns on those).
mask() {
  [[ -n "$1" ]] && printf '::add-mask::%s\n' "$1" || true
}

# Call the Vault HTTP API: vault_api METHOD PATH [JSON_BODY] -> response body.
vault_api() {
  local method=$1 path=$2 body=${3:-}
  local args=(--fail --silent --show-error --location
    -X "$method" -H "X-Vault-Namespace: $VAULT_NAMESPACE")
  [[ -n "${VAULT_TOKEN:-}" ]] && args+=(-H "X-Vault-Token: $VAULT_TOKEN")
  [[ -n "$body" ]] && args+=(-H "Content-Type: application/json" --data "$body")
  curl "${args[@]}" "$VAULT_ADDR/v1/$path"
}

# 1. Mint a GitHub Actions OIDC token for our audience.
id_token=$(curl --fail --silent --show-error \
  -H "Authorization: bearer $ACTIONS_ID_TOKEN_REQUEST_TOKEN" \
  "$ACTIONS_ID_TOKEN_REQUEST_URL&audience=$AUDIENCE" | jq -r '.value')

# 2. Exchange it for a Vault token.
login_body=$(jq -n --arg role "$VAULT_AUTH_ROLE" --arg jwt "$id_token" \
  '{role: $role, jwt: $jwt}')
VAULT_TOKEN=$(vault_api POST "auth/$AUTH_PATH/login" "$login_body" \
  | jq -r '.auth.client_token')
export VAULT_TOKEN
mask "$VAULT_TOKEN"

put_env VAULT_ADDR "$VAULT_ADDR"
put_env VAULT_NAMESPACE "$VAULT_NAMESPACE"
if [[ "${EXPORT_VAULT_TOKEN:-}" == "true" ]]; then
  put_env VAULT_TOKEN "$VAULT_TOKEN"
fi

# 3. Fetch each requested secret into the environment.
pinned=''
for arg in "$@"; do
  # Strip any "@version" suffix; an unsuffixed arg leaves key == arg.
  key=${arg%@*}
  if [[ "$arg" == "$key" ]]; then
    version=''
  else
    version=${arg#*@}
  fi
  env_name=${key##*/} # the last path component is the environment variable name
  path="$MOUNT/data/$key"
  [[ -n "$version" ]] && path="$path?version=$version"
  json=$(vault_api GET "$path")
  got_version=$(printf '%s' "$json" | jq -r '.data.metadata.version')
  value=$(printf '%s' "$json" | jq -r '.data.data.value')
  mask "$value"
  put_env "$env_name" "$value"
  pinned="$pinned $key@$got_version"
done

# Record what we injected, for reproducibility and auditing.
printf 'Injected secret versions:%s\n' "$pinned" >&2
if [[ -n "${GITHUB_OUTPUT:-}" ]]; then
  printf 'pinned=%s\n' "${pinned# }" >> "$GITHUB_OUTPUT"
fi
